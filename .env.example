# ===== Notion =====
# https://www.notion.so/profile/integrations 에서 내부 통합(Integration)을 만들고 토큰을 복사하세요.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 보고서 입력/출력에 사용할 데이터베이스 ID (URL 의 32자리 hex)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== LLM (Gemini) =====
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 무료 티어는 gemini-2.5-pro 사용 불가(quota 0). 무료면 flash, 유료 결제 시 pro 가능.
GEMINI_MODEL=gemini-2.5-flash

# ===== Notion 컬럼(속성) 이름 — Notion 테이블의 실제 컬럼명과 일치해야 함 =====
PROP_COMPANY=회사정보
PROP_MEETING=회의록
PROP_STATUS=상태
PROP_REPORT_DATE=보고서생성일
PROP_REPORT_FILE=보고서
PROP_ERROR=오류메시지

# 상태 값 (select / status 옵션 이름)
STATUS_PENDING=미처리
STATUS_PROCESSING=처리중
STATUS_DONE=완료
STATUS_ERROR=오류

# docx 보고서를 생성해 '보고서' 파일 컬럼에 첨부할지 여부 (true/false)
ATTACH_DOCX=true

# ===== 폴링 =====
POLL_INTERVAL_SECONDS=60
